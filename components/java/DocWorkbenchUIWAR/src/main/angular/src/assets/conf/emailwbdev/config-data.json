{
  "config": {
    "environment": "emailwb-dev",
    "docwbServiceBaseUrl": "http://localhost:80/docwbservice",
    "docwbFileServerBaseUrl": "http://localhost:80/docwbservice",
    "docwbWebBaseUrl": "http://localhost:80/emailwb",
    "tenantId": "<TenantId>",
    "modelServiceUrl":"http://localhost:8003",
    "title": "Email Workbench",
    "origDocAnnWhenPlainTxtAvailable": 2,
    "origDocAnnWhenPlainTxtUnavailable": 3,
    "sidebar": {
      "queueModeFlatVisible": true,
      "queueModeFlatEnabled": true,
      "queueModeHierarchyVisible": true,
      "queueModeHierarchyEnabled": true,
      "queueModeHierarchyDelimiter": ":"
    },
    "telemetry": {
      "enabled": true,
      "serviceBaseUrl": "http://localhost:80/telemetryservice",
      "authtoken": {
        "tokenName": "web-core"
      }
    },
    "application": {
      "webVersionValidation": {
        "enabled": true,
        "checkIntervalInSecs": 300
      }
    },
    "queue":{
      "queueVisibilityAfterClosureInDays":7
    }
  }
}
