 <service>
      <id>Infosys Email Workbench Rules</id>
      <name>Infosys Email Workbench Rules</name>
      <description>This service runs Emailwb Rules application.</description>
      <env name="MYAPP_HOME" value="%BASE%"/>
      <executable>java</executable>
      <arguments>-jar "%BASE%\docwb-rules.war"</arguments>
      <logmode>rotate</logmode>
    </service>